<UserControl x:Class="MarkdownVault.Views.FileTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MarkdownVault.ViewModels">

    <UserControl.Resources>
        <!-- Recursive template so folders show their children -->
        <HierarchicalDataTemplate DataType="{x:Type vm:VaultFileNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsVisible,
                                     Converter={StaticResource BoolToVisConverter}}">
                <!-- Folder / file icon -->
                <TextBlock Text="{Binding IsDirectory,
                                  Converter={StaticResource BoolToIconConverter}}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Margin="0,0,5,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource PanelBackground}">

        <!-- Header toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ToolBarBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel>
                <TextBlock Text=""
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleForeground}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- New file: a page with a folded corner and a plus -->
                    <Button ToolTip="Nuevo archivo"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding CreateFileCommand}">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M4,2 H9 L12,5 V13 H4 Z M9,2 V5 H12 M8,7.2 V11 M6.1,9.1 H9.9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </Button>

                    <!-- New folder: a folder with a plus -->
                    <Button ToolTip="Nueva carpeta"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding CreateFolderCommand}">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M2,4.2 H6 L7.5,5.7 H14 V13 H2 Z M8,8.2 V11.6 M6.3,9.9 H9.7"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border DockPanel.Dock="Top"
                Padding="6,4"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchBoxStyle}"
                     Tag="Buscar archivos…"/>
        </Border>

        <!-- Tree -->
        <TreeView x:Name="FileTree"
                  ItemsSource="{Binding RootNodes}"
                  Background="{DynamicResource PanelBackground}"
                  BorderThickness="0"
                  Padding="4"
                  SelectedItemChanged="FileTree_SelectedItemChanged"
                  MouseDoubleClick="FileTree_MouseDoubleClick">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="Padding"    Value="2,2"/>
                    <Setter Property="FontSize"   Value="13"/>
                    <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SelectionBackground}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ContextMenu>
                <!-- PlacementTarget.DataContext re-binds to the TreeView's DataContext
                     because ContextMenu lives outside the visual tree. -->
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                          RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Abrir"
                              Command="{Binding OpenFileCommand}"
                              CommandParameter="{Binding SelectedNode}"/>
                    <Separator/>
                    <MenuItem Header="Nuevo archivo"  Command="{Binding CreateFileCommand}"/>
                    <MenuItem Header="Nueva carpeta" Command="{Binding CreateFolderCommand}"/>
                    <Separator/>
                    <MenuItem Header="Renombrar"
                              Command="{Binding RenameNodeCommand}"
                              CommandParameter="{Binding SelectedNode}"/>
                    <MenuItem Header="Eliminar"
                              Command="{Binding DeleteNodeCommand}"
                              CommandParameter="{Binding SelectedNode}"/>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </DockPanel>
</UserControl>
