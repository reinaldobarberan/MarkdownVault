<Window x:Class="MarkdownVault.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MarkdownVault.Views"
        xmlns:vm="clr-namespace:MarkdownVault.ViewModels"
        xmlns:models="clr-namespace:MarkdownVault.Models"
        Title="{Binding Editor.Title}"
        Icon="pack://application:,,,/image/barra.ico"
        Height="800" Width="1300"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        Closing="Window_Closing">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl"            Command="{Binding Editor.SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift"   Command="{Binding Editor.SaveAsCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl"       Command="{Binding Editor.CloseTabCommand}"
                    CommandParameter="{Binding Editor.ActiveTab}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl"     Command="{Binding Editor.NextTabCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl+Shift" Command="{Binding Editor.PreviousTabCommand}"/>
        <KeyBinding Key="OemPipe" Modifiers="Ctrl" Command="{Binding ToggleExplorerCommand}"/>
        <KeyBinding Key="Left" Modifiers="Alt"     Command="{Binding Editor.GoBackCommand}"/>
        <KeyBinding Key="OemPlus"  Modifiers="Ctrl" Command="{Binding IncreaseFontSizeCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding DecreaseFontSizeCommand}"/>
        <KeyBinding Key="D0"       Modifiers="Ctrl" Command="{Binding ResetPreviewZoomCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- VS Code-style view-mode layout toggle button -->
        <Style x:Key="ViewToggleButtonStyle" TargetType="Button"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Menu bar + view-mode toggles ── -->
        <DockPanel DockPanel.Dock="Top"
                   Background="{DynamicResource ToolBarBackground}">

            <!-- View-mode layout toggles (always visible, work in every mode) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="4,0,8,0">

                <!-- Toggle explorer: sidebar panel (highlighted while shown) -->
                <Button ToolTip="Mostrar/ocultar explorador (Ctrl+\)"
                        Command="{Binding ToggleExplorerCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ViewToggleButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExplorerVisible}" Value="True">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="16" Height="16">
                        <Grid>
                            <Path Data="M2.5,3.5 H6 V12.5 H2.5 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Opacity="0.4"/>
                            <Path Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M6,3.5 V12.5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2" StrokeLineJoin="Round"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <Border Width="1" Margin="5,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Solo editor: single left pane active -->
                <Button ToolTip="Solo editor"
                        Command="{Binding Editor.SetViewModeCommand}"
                        CommandParameter="{x:Static models:ViewMode.EditorOnly}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ViewToggleButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor.ViewMode}" Value="{x:Static models:ViewMode.EditorOnly}">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="16" Height="16">
                        <Grid>
                            <Path Data="M2.5,3.5 H8 V12.5 H2.5 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Opacity="0.5"/>
                            <Path Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M8,3.5 V12.5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2" StrokeLineJoin="Round"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <!-- Editor + vista: two side-by-side panes -->
                <Button ToolTip="Editor y vista previa"
                        Command="{Binding Editor.SetViewModeCommand}"
                        CommandParameter="{x:Static models:ViewMode.EditAndPreview}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ViewToggleButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor.ViewMode}" Value="{x:Static models:ViewMode.EditAndPreview}">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="16" Height="16">
                        <Path Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M8,3.5 V12.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" StrokeLineJoin="Round"/>
                    </Viewbox>
                </Button>

                <!-- Solo visor: single right pane active -->
                <Button ToolTip="Solo visor"
                        Command="{Binding Editor.SetViewModeCommand}"
                        CommandParameter="{x:Static models:ViewMode.ViewerOnly}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ViewToggleButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor.ViewMode}" Value="{x:Static models:ViewMode.ViewerOnly}">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="16" Height="16">
                        <Grid>
                            <Path Data="M8,3.5 H13.5 V12.5 H8 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Opacity="0.5"/>
                            <Path Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M8,3.5 V12.5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2" StrokeLineJoin="Round"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <Border Width="1" Margin="5,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Graph view toggle (highlighted while active) -->
                <Button ToolTip="Vista de grafo"
                        Command="{Binding Editor.ToggleGraphCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ViewToggleButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor.ShowGraph}" Value="True">
                                    <Setter Property="Background" Value="#094771"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="16" Height="16">
                            <Line X1="4.5" Y1="4.5" X2="12.5" Y2="6.5" Stroke="#8B8B8B" StrokeThickness="1"/>
                            <Line X1="12.5" Y1="6.5" X2="6.5" Y2="12.5" Stroke="#8B8B8B" StrokeThickness="1"/>
                            <Ellipse Canvas.Left="2"  Canvas.Top="2"  Width="5" Height="5" Fill="#6F9FD8"/>
                            <Ellipse Canvas.Left="10" Canvas.Top="4"  Width="5" Height="5" Fill="#6F9FD8"/>
                            <Ellipse Canvas.Left="4"  Canvas.Top="10" Width="5" Height="5" Fill="#6F9FD8"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>

            <Menu Background="Transparent"
                  Foreground="{DynamicResource Foreground}"
                  FontSize="13">
            <MenuItem Header="_Archivo">
                <MenuItem Header="_Abrir vault…"    Command="{Binding OpenVaultCommand}" InputGestureText="Ctrl+Shift+O"/>
                <MenuItem Header="_Nuevo archivo"   Command="{Binding NewFileCommand}"   InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="_Guardar"         Command="{Binding Editor.SaveCommand}"   InputGestureText="Ctrl+S"/>
                <MenuItem Header="Guardar _como…"   Command="{Binding Editor.SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="E_xportar vista a PNG…" Click="ExportToPng_Click" InputGestureText="Ctrl+Shift+P"/>
                <Separator/>
                <MenuItem Header="_Salir" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Vista">
                <MenuItem Header="_Explorador"
                          Command="{Binding ToggleExplorerCommand}"
                          InputGestureText="Ctrl+\"/>
                <Separator/>
                <MenuItem Header="Solo _editor"
                          Command="{Binding Editor.SetViewModeCommand}"
                          CommandParameter="{x:Static models:ViewMode.EditorOnly}"/>
                <MenuItem Header="_Editor y vista previa"
                          Command="{Binding Editor.SetViewModeCommand}"
                          CommandParameter="{x:Static models:ViewMode.EditAndPreview}"/>
                <MenuItem Header="Solo _visor"
                          Command="{Binding Editor.SetViewModeCommand}"
                          CommandParameter="{x:Static models:ViewMode.ViewerOnly}"/>
                <Separator/>
                <MenuItem Header="Aumentar fuente y zoom" Command="{Binding IncreaseFontSizeCommand}" InputGestureText="Ctrl++"/>
                <MenuItem Header="Reducir fuente y zoom"  Command="{Binding DecreaseFontSizeCommand}" InputGestureText="Ctrl+-"/>
                <MenuItem Header="Restablecer zoom"        Command="{Binding ResetPreviewZoomCommand}" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="Cambiar _tema"   Command="{Binding ToggleThemeCommand}"/>
            </MenuItem>
            </Menu>
        </DockPanel>

        <!-- ── Global tab bar (always visible, independent of view mode) ── -->
        <Border DockPanel.Dock="Top"
                DataContext="{Binding Editor}"
                Background="{DynamicResource TabBarBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasFile, Converter={StaticResource BoolToVisConverter}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Padding="0">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Height" Value="3"/>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding OpenTabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    Background="{DynamicResource TabInactiveBackground}"
                                    BorderThickness="0,2,0,0"
                                    BorderBrush="Transparent"
                                    Margin="0,0,1,0"
                                    Padding="10,5,4,5"
                                    Cursor="Hand"
                                    MinWidth="80" MaxWidth="200"
                                    MouseLeftButtonDown="Tab_MouseLeftButtonDown"
                                    MouseDown="Tab_MouseDown">
                                <DockPanel>
                                    <!-- Close button -->
                                    <Button x:Name="CloseBtn"
                                            DockPanel.Dock="Right"
                                            Content="&#xE711;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="9"
                                            Width="18" Height="18"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            Opacity="0"
                                            Command="{Binding DataContext.CloseTabCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CloseBg"
                                                        Background="Transparent"
                                                        CornerRadius="3"
                                                        Padding="2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      TextElement.Foreground="{DynamicResource SubtleForeground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CloseBg" Property="Background"
                                                                Value="{DynamicResource TabCloseHover}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- File name -->
                                    <TextBlock x:Name="TabText"
                                               Text="{Binding DisplayName}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TabInactiveForeground}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Show close on hover (declared first so active overrides) -->
                                <Trigger SourceName="TabBorder" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBtn" Property="Opacity" Value="1"/>
                                    <Setter TargetName="TabBorder" Property="Background"
                                            Value="{DynamicResource TabHoverBackground}"/>
                                </Trigger>
                                <!-- Active tab styling (declared last → wins over hover) -->
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background"
                                            Value="{DynamicResource TabActiveBackground}"/>
                                    <Setter TargetName="TabBorder" Property="BorderBrush"
                                            Value="{DynamicResource TabActiveBorder}"/>
                                    <Setter TargetName="TabText" Property="Foreground"
                                            Value="{DynamicResource Foreground}"/>
                                    <Setter TargetName="CloseBtn" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Status bar ── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource StatusBarBackground}"
                   Foreground="{DynamicResource StatusBarForeground}"
                   FontSize="12">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Vault: " />
                    <Run Text="{Binding VaultName, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Lín "/>
                    <Run Text="{Binding Editor.CurrentLine, Mode=OneWay}"/>
                    <Run Text=", Col "/>
                    <Run Text="{Binding Editor.CurrentColumn, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="{Binding Editor.WordCount, Mode=OneWay}"/>
                    <Run Text=" palabras"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding Editor.StatusMessage, Mode=OneWay}"
                           Foreground="{DynamicResource StatusBarForeground}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main layout: FileTree | Editor | Preview ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn" Width="240" MinWidth="0" MaxWidth="500"/>
                <ColumnDefinition x:Name="ExplorerSplitterColumn" Width="4"/>
                <ColumnDefinition x:Name="EditorColumn"      Width="*" MinWidth="200"/>
                <ColumnDefinition x:Name="MidSplitterColumn" Width="4"/>
                <ColumnDefinition x:Name="PreviewColumn"     Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- File tree -->
            <local:FileTreeView Grid.Column="0"
                                x:Name="FileTreePanel"
                                DataContext="{Binding FileTree}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,1,0"/>

            <!-- Splitter between explorer and editor -->
            <GridSplitter Grid.Column="1"
                          x:Name="ExplorerSplitter"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBackground}"
                          ShowsPreview="True"/>

            <!-- Editor -->
            <local:EditorView Grid.Column="2"
                              DataContext="{Binding Editor}"
                              x:Name="EditorPanel"
                              FontFamily="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                              FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <GridSplitter Grid.Column="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBackground}"
                          ShowsPreview="True"/>

            <!-- Preview (WebView2) -->
            <Border Grid.Column="4"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding Editor.ShowPreviewPanel,
                                 Converter={StaticResource BoolToVisConverter}}">
                <wv2:WebView2 x:Name="PreviewWebView"
                              DefaultBackgroundColor="White"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
