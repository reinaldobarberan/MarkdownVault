<UserControl x:Class="MarkdownVault.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MarkdownVault.Views">

    <UserControl.Resources>

        <!-- ── Section header ("FILTROS", "FUERZAS", "MOSTRAR") ── -->
        <Style x:Key="GraphSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#8B8B8B"/>
            <Setter Property="Margin"        Value="0,0,0,6"/>
        </Style>

        <!-- ── Toggle switch (34×18 pill) ── -->
        <Style x:Key="GraphToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="34"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="9" Background="#484848">
                            <Border x:Name="Knob" Width="14" Height="14" CornerRadius="7"
                                    Background="White"
                                    HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Knob"  Property="Margin"     Value="18,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Compact slider ── -->
        <Style x:Key="GraphSliderStyle" TargetType="Slider">
            <Setter Property="Minimum"            Value="0.2"/>
            <Setter Property="Maximum"            Value="2.5"/>
            <Setter Property="SmallChange"        Value="0.1"/>
            <Setter Property="LargeChange"        Value="0.1"/>
            <Setter Property="TickFrequency"      Value="0.1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Height"             Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#3C3C3C"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12"
                                                         Fill="{DynamicResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Zoom control button (30×30) ── -->
        <Style x:Key="GraphZoomButtonStyle" TargetType="Button">
            <Setter Property="Width"      Value="30"/>
            <Setter Property="Height"     Value="30"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Force-slider row ── -->
        <Style x:Key="GraphSliderLabel" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Foreground"    Value="{DynamicResource Foreground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <!-- Canvas + floating overlays -->
    <Grid ClipToBounds="True">

        <local:GraphCanvas x:Name="Canvas"/>

        <!-- ── Filter panel (top-left) ── -->
        <Border Width="232"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="14"
                Background="{DynamicResource GraphPanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="FILTROS" Style="{StaticResource GraphSectionHeader}"/>

                <TextBox Style="{StaticResource SearchBoxStyle}"
                         Tag="Buscar nodos…"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <!-- Local graph toggle -->
                <DockPanel Margin="0,0,0,4">
                    <ToggleButton DockPanel.Dock="Right"
                                  Style="{StaticResource GraphToggleStyle}"
                                  IsChecked="{Binding LocalGraph}"/>
                    <TextBlock Text="Grafo local del archivo activo"
                               Style="{StaticResource GraphSliderLabel}"
                               TextWrapping="Wrap" Margin="0,0,8,0"/>
                </DockPanel>

                <Separator Margin="0,10" Background="{DynamicResource BorderBrush}"/>

                <TextBlock Text="FUERZAS" Style="{StaticResource GraphSectionHeader}"/>

                <!-- Central force -->
                <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="Fuerza central" Style="{StaticResource GraphSliderLabel}"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ForceCenter, StringFormat=0.0}"
                               Foreground="{DynamicResource GraphValueBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
                <Slider Style="{StaticResource GraphSliderStyle}"
                        Value="{Binding ForceCenter}" Margin="0,0,0,10"/>

                <!-- Repulsion -->
                <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="Repulsión" Style="{StaticResource GraphSliderLabel}"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ForceRepel, StringFormat=0.0}"
                               Foreground="{DynamicResource GraphValueBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
                <Slider Style="{StaticResource GraphSliderStyle}"
                        Value="{Binding ForceRepel}" Margin="0,0,0,10"/>

                <!-- Links -->
                <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="Enlaces" Style="{StaticResource GraphSliderLabel}"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ForceLink, StringFormat=0.0}"
                               Foreground="{DynamicResource GraphValueBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
                <Slider Style="{StaticResource GraphSliderStyle}"
                        Value="{Binding ForceLink}" Margin="0,0,0,4"/>

                <Separator Margin="0,10" Background="{DynamicResource BorderBrush}"/>

                <TextBlock Text="MOSTRAR" Style="{StaticResource GraphSectionHeader}"/>
                <DockPanel>
                    <ToggleButton DockPanel.Dock="Right"
                                  Style="{StaticResource GraphToggleStyle}"
                                  IsChecked="{Binding ShowLabels}"/>
                    <TextBlock Text="Etiquetas" Style="{StaticResource GraphSliderLabel}"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ── Legend / counters (bottom-left) ── -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="14"
                Background="{DynamicResource GraphPanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,7">
            <TextBlock FontSize="11" Foreground="{DynamicResource SubtleForeground}">
                <Run Text="{Binding NoteCount, Mode=OneWay}"/><Run Text=" notas"/>
                <Run Text="  ·  "/>
                <Run Text="{Binding LinkCount, Mode=OneWay}"/><Run Text=" enlaces"/>
            </TextBlock>
        </Border>

        <!-- ── Zoom controls (bottom-right) ── -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="14"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <Button Style="{StaticResource GraphZoomButtonStyle}"
                        Content="+" ToolTip="Acercar" Click="ZoomIn_Click"/>
                <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                <Button Style="{StaticResource GraphZoomButtonStyle}"
                        Content="&#x2212;" ToolTip="Alejar" Click="ZoomOut_Click"/>
                <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                <Button Style="{StaticResource GraphZoomButtonStyle}"
                        Content="&#x2299;" ToolTip="Centrar" Click="Reset_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
