<Window x:Class="MarkdownVault.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">

    <!-- Rounded card that follows the active theme -->
    <Border Width="380"
            Margin="24"
            CornerRadius="12"
            Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Padding="0,32,0,26">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.45" Color="Black"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/image/logo_app.png"
                   Width="160" Height="160"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="MarkdownVault"
                       Foreground="{DynamicResource Foreground}"
                       FontFamily="Segoe UI"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,2"/>

            <TextBlock Text="Editor de Markdown tipo Obsidian"
                       Foreground="{DynamicResource SubtleForeground}"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       HorizontalAlignment="Center"/>

            <!-- Indeterminate accent bar -->
            <Border Width="180" Height="3"
                    CornerRadius="2"
                    Margin="0,22,0,0"
                    ClipToBounds="True"
                    Background="{DynamicResource BorderBrush}">
                <Border x:Name="Pulse"
                        Width="70" Height="3"
                        HorizontalAlignment="Left"
                        CornerRadius="2"
                        Background="{DynamicResource AccentBrush}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PulseShift" X="-70"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="PulseShift"
                                     Storyboard.TargetProperty="X"
                                     From="-70" To="180" Duration="0:0:1.1"
                                     AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
